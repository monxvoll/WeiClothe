# BuildKit (required for --mount=type=cache in Dockerfile)
DOCKER_BUILDKIT=1
COMPOSE_DOCKER_CLI_BUILD=1

# Logging: text (human-readable, default) | json (structured, for prod/aggregators)
LOG_FORMAT=text

KEYCLOAK_BASE_URL=http://localhost:9090
KEYCLOAK_REALM=YOUR_REALM_NAME
KEYCLOAK_CLIENT_ID=YOUR_CLIENT_ID
KEYCLOAK_CLIENT_SECRET=YOUR_CLIENT_SECRET_KEY
# HTTP timeout for Keycloak adapter (seconds); default 10
KEYCLOAK_HTTP_TIMEOUT_SECONDS=10

# vusion-ml (Docker Compose)
# Local dev: usa keycloak:8080 (nombre de servicio Docker interno).
# EC2/prod: pon la IP pública para que el issuer del JWT coincida con el cliente.
VISION_ML_CLIENT_ID=vision-ml
VISION_ML_CLIENT_SECRET=YOUR_VISION_ML_CLIENT_SECRET
# Local:
VISION_ML_KEYCLOAK_BASE_URL=http://keycloak:8080
# EC2: VISION_ML_KEYCLOAK_BASE_URL=http://EC2_PUBLIC_IP:9090

# Kafka broker address (EXTERNAL listener exposed to host)
KAFKA_BROKERS=localhost:9093

# Topic for garment ML jobs (Go publishes after POST /clothes multipart; vusion-ml consumes).
KAFKA_TOPIC_ANALYSIS=vusion.analysis.request
KAFKA_TOPIC_ANALYSIS_DLQ=vusion.analysis.dlq
# Leave unset to use default vusion.analysis.request. Set to empty string to disable analysis publishing (no S3 staging required).
# KAFKA_TOPIC_ANALYSIS=

# S3-compatible staging for raw uploads (required when KAFKA_TOPIC_ANALYSIS is non-empty). Same bucket as vusion-ml.
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=minio
AWS_SECRET_ACCESS_KEY=miniosecret
S3_BUCKET=weicloth
# Dev MinIO (host): http://localhost:9000 ; Docker Compose API uses http://minio:9000 (see docker-compose.yml)
S3_ENDPOINT_URL=http://localhost:9000

# Public base for garment image URLs (vusion-ml → clothes.image_url). Path-style: <S3_PUBLIC_BASE_URL>/<object-key>.
# Local dev (default in docker-compose for vusion-ml): http://localhost:9000/weicloth — minio-init enables anonymous download on bucket.
# Remote dev / EC2 with MinIO exposed: http://<host>:9000/weicloth
# Prod AWS: CloudFront or S3 website URL, e.g. https://d1234567890.cloudfront.net or https://my-bucket.s3.amazonaws.com
# Private bucket (no public read): leave unset in vusion-ml only — then presigned GET URLs (24h) are stored instead.
S3_PUBLIC_BASE_URL=http://localhost:9000/weicloth

#Postgres
DB_HOST=YOUR_HOST
DB_PORT=YOUR_PORT
DB_USER=YOUR_USER
DB_PASSWORD=YOUR_PASSWORD
DB_NAME=YOUR_DB_NAME
DB_SSLMODE=disable (local), require or verify-full (Aurora)

# For register, login and verify token workflow
TEST_USER_EMAIL=YOUR_EMAIL
TEST_USER_PASS=YOUR_PASSWORD