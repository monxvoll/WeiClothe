# En el host (sin Docker): puerto EXTERNAL de Redpanda
KAFKA_BROKERS=localhost:9093
# Con docker compose: usa kafka:9092 dentro de la red compose (ya definido en compose)

KEYCLOAK_BASE_URL=http://localhost:9090
# Con docker compose por defecto: http://keycloak:8080 (ver docker-compose en la raíz de GoClient)
KEYCLOAK_REALM=weiclothe
KEYCLOAK_CLIENT_ID=vision-ml
KEYCLOAK_CLIENT_SECRET=<your-vision-ml-client-secret-from-keycloak>

# Optional: DLQ after 3 failed processing attempts (consumer republishes with incrementing `attempt`).
KAFKA_TOPIC_ANALYSIS_DLQ=vusion.analysis.dlq
MIDDLEWARE_STRICT_STARTUP=true
MIDDLEWARE_HTTP_TIMEOUT_SECONDS=10
# Reintentos al arrancar si Keycloak aún importa el realm (Compose / EC2 lentos)
KEYCLOAK_BOOTSTRAP_ATTEMPTS=40
KEYCLOAK_BOOTSTRAP_DELAY_SEC=3
LOG_LEVEL=INFO
FLASK_DEBUG=false

# ── Analysis consumer (ENABLE_ANALYSIS_CONSUMER=true): central DB + S3 ──
ENABLE_ANALYSIS_CONSUMER=true
KAFKA_GROUP_ID=vusion-ml-analysis
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=weicloth
DB_SSLMODE=disable
# Dev MinIO; prod AWS S3 (leave S3_ENDPOINT_URL empty; optional IAM role — omit AWS keys)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=minio
AWS_SECRET_ACCESS_KEY=miniosecret
S3_BUCKET=weicloth
S3_ENDPOINT_URL=http://localhost:9000
# Stored in DB as prefix for processed image keys. Dev: path-style MinIO + anonymous download (see GoClient docker-compose minio-init).
# Remote: http://<host>:9000/weicloth
# Prod CDN: https://d1234567890.cloudfront.net (no trailing slash)
# Private AWS bucket: unset S3_PUBLIC_BASE_URL → presigned URLs (24h) instead of public paths
S3_PUBLIC_BASE_URL=http://localhost:9000/weicloth
YOLO_MODEL=yolov8n-seg.pt
CLIP_MODEL=openai/clip-vit-base-patch32
# Max image size accepted by the ML pipeline (MB). Images above this limit are rejected.
MAX_IMAGE_SIZE_MB=20
# Comma-separated list of allowed CORS origins (e.g. http://localhost:4200,https://app.example.com).
# Leave empty to block all cross-origin requests.
CORS_ALLOWED_ORIGINS=http://localhost:4200
